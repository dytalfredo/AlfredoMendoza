---
// src/layouts/CourseLayout.astro
// Layout base independiente para la landing page del curso
import "../styles/global.css";

interface Props {
    title: string;
    description: string;
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    ogImageAlt?: string;
    ogType?: string;
    ogUrl?: string;
    keywords?: string;
    author?: string;
}

const {
    title,
    description,
    ogTitle = title,
    ogDescription = description,
    ogImage = "/images/og-image.jpg", // Update if specific image is provided
    ogType = "website",
    ogUrl = Astro.url.href,
    keywords = "Marketing Digital, Inteligencia Artificial, Curso, Certificación, Alfredo Mendoza",
    author = "Alfredo Mendoza",
    ogImageAlt = title,
} = Astro.props;

// Ensure absolute URL for OG image
const absoluteOgImage = ogImage.startsWith("http")
    ? ogImage
    : `https://alfredomendoza.netlify.app${ogImage}`;
---

<!doctype html>
<html lang="es" class="scroll-smooth dark">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/images/favicon.webp" />
        <meta name="generator" content={Astro.generator} />

        <!-- SEO & Meta Tags -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="author" content={author} />

        <!-- Open Graph (Facebook/LinkedIn) -->
        <meta property="og:title" content={ogTitle} />
        <meta property="og:description" content={ogDescription} />
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={ogUrl} />
        <meta property="og:image" content={absoluteOgImage} />
        <meta property="og:image:alt" content={ogImageAlt} />
        <meta
            property="og:site_name"
            content="Certificación Marketing IA - Alfredo Mendoza"
        />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={ogTitle} />
        <meta name="twitter:description" content={ogDescription} />
        <meta name="twitter:image" content={absoluteOgImage} />

        <!-- Fonts and Icons for Landing Page -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />

        <!-- Global Styles for Landing Page -->
        <style is:global>
            html {
                scroll-padding-top: 80px;
                scroll-behavior: smooth;
            }
            body {
                font-family: "Inter", sans-serif;
            }
            .material-symbols-outlined {
                font-variation-settings:
                    "FILL" 0,
                    "wght" 400,
                    "GRAD" 0,
                    "opsz" 24;
            }

            /* Animations for Landing Page */
            @keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translate3d(0, 40px, 0);
                }
                to {
                    opacity: 1;
                    transform: translate3d(0, 0, 0);
                }
            }

            @keyframes fadeInLeft {
                from {
                    opacity: 0;
                    transform: translate3d(-40px, 0, 0);
                }
                to {
                    opacity: 1;
                    transform: translate3d(0, 0, 0);
                }
            }

            @keyframes fadeInRight {
                from {
                    opacity: 0;
                    transform: translate3d(40px, 0, 0);
                }
                to {
                    opacity: 1;
                    transform: translate3d(0, 0, 0);
                }
            }

            .animate-fade-in-up {
                animation: fadeInUp 1.2s ease-out forwards;
                opacity: 0; /* Starting state */
            }

            .animate-fade-in-left {
                animation: fadeInLeft 1.2s ease-out forwards;
                opacity: 0;
            }

            .animate-fade-in-right {
                animation: fadeInRight 1.2s ease-out forwards;
                opacity: 0;
            }

            /* Add an animation-timeline to trigger animations on scroll when supported */
            @supports (animation-timeline: view()) {
                .animate-fade-in-up,
                .animate-fade-in-left,
                .animate-fade-in-right {
                    animation-timeline: view();
                    animation-range: entry 10% cover 30%;
                }
            }
        </style>

        <slot name="head" />
    </head>
    <body class="bg-[#0b0e14] text-slate-100 antialiased overflow-x-hidden">
        <div
            class="relative flex h-auto min-h-screen w-full flex-col group/design-root"
        >
            <div class="layout-container flex h-full grow flex-col">
                <slot />
            </div>
        </div>
    </body>
</html>
