---
// src/components/curso/HeroSection.astro
---

<section
    class="px-6 lg:px-20 py-12 lg:py-24 bg-gradient-to-br from-[#0b0e14] to-[#1e1b4b] animate-fade-in-up"
>
    <div
        class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
    >
        <div class="flex flex-col gap-8">
            <div
                class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-accent/20 text-accent ring-1 ring-accent/30 self-start"
            >
                <span class="relative flex h-2 w-2">
                    <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex rounded-full h-2 w-2 bg-accent"
                    ></span>
                </span>
                ÚLTIMOS 15 CUPOS DISPONIBLES
            </div>

            <h1
                class="text-white text-4xl lg:text-6xl font-black leading-tight tracking-tight"
            >
                Aprende Marketing Digital con <span class="text-primary"
                    >IA</span
                > trabajando con empresas reales
            </h1>

            <p class="text-slate-400 text-lg lg:text-xl leading-relaxed">
                Certificación profesional de 120 horas con proyectos prácticos y
                tutoría personalizada. Domina las herramientas del futuro hoy
                mismo y escala tus resultados.
            </p>

            <div class="flex flex-wrap gap-4">
                <button
                    class="flex min-w-[200px] cursor-pointer items-center justify-center rounded-lg h-14 px-8 bg-accent text-white text-lg font-bold shadow-xl shadow-accent/20 hover:scale-105 transition-all shadow-[0_0_20px_-3px_rgba(249,115,22,0.6)]"
                >
                    Reservar mi lugar
                </button>
                <a
                    href="#programa"
                    class="flex min-w-[200px] cursor-pointer items-center justify-center rounded-lg h-14 px-8 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white text-lg font-bold hover:bg-slate-50 dark:hover:bg-slate-700 transition-all"
                >
                    Ver programa
                </a>
            </div>

            <div class="flex items-center gap-4 pt-4">
                <div class="flex -space-x-3">
                    <div
                        class="h-10 w-10 rounded-full border-2 border-white dark:border-slate-900 bg-slate-200 overflow-hidden"
                        data-alt="Profile picture of a professional marketer"
                    >
                        <img
                            alt="Estudiante Graduado 1"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBtVq6r0ZJZHdCtcmx66UfsaC366Ib3Il71s80ry02a9kmygJEVfTbAge7TfZQyhyQh7H0dND7wIjnLf1ZSHnUBRdAmQOt-Yj5QygPMc8nBXOjNUzLaoEY6yA8oaSkLj_lNo8jXaxfG19TfYTmDyYohwx5x0HP6mv6yKlURSTa0XYXQLYYLDspKnBidaoGZL0DudCS_xs1s87Uy2wtkro6jCioIKpri04rOjsokzMCy7uh3CHYK-zLHC3QDMCG1KikPn7Ra8ZXvag"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <div
                        class="h-10 w-10 rounded-full border-2 border-white dark:border-slate-900 bg-slate-200 overflow-hidden"
                        data-alt="Profile picture of an entrepreneur student"
                    >
                        <img
                            alt="Estudiante Graduado 2"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCVp5ihfpywCm-HeY67dNZYPnOKX6iCW3N7kD25iMbz03n7efsXO1r4B62M3eEsFjuYZoKAEpM7mFS9d5fa-d__59AbJDPtrsRrjQIQt5XuAmYSyQ-3QcYcEdTcKiYcFJeeRKQWD2Q9cY9iq-Us9XEKG3QFgaEvid62xJGDYUbqjqhPqk2Na1PTKn1iCeaJFuATFaIJXYQFvo2_vwBwz-lxk5d-2jFlzEqE0X6rcw9M7830DoyQlwMEtVy6aN-GbPt6O4EeIz80bg"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <div
                        class="h-10 w-10 rounded-full border-2 border-white dark:border-slate-900 bg-slate-200 overflow-hidden"
                        data-alt="Profile picture of a content creator"
                    >
                        <img
                            alt="Estudiante Graduado 3"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuACZzg70c3BIjh0M-yTmhNLNnCX4-skUE1Lj9_ZRjM7TpDdQvy3Uj33GKNXiuLGFeo5A5Hq0FVon7FCiJvEyo7wAJXvy6K3XJWqRKHvrXs5BuurjbEf7vQ49typ4Sc5SnyANCi7PbMUByRq8mlol3MlBi3JVJ_aGiVT1Ys9Dv4YsVMxJCud9Qxrr957KeGQoI_eUA5jmYxmdqPMePLAD_LCnxKQ9YAvNqHg7MW51VgEXA16Qq9YziBcgjklP9AeGxiLr9i7AJSmpA"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
                <p class="text-slate-400 text-lg lg:text-xl leading-relaxed">
                    +2,500 graduados con éxito
                </p>
            </div>
        </div>

        <div class="relative group">
            <div
                class="absolute -inset-4 bg-primary/20 rounded-3xl blur-2xl group-hover:bg-primary/30 transition duration-1000"
            >
            </div>
            <div
                class="relative bg-white dark:bg-slate-800 rounded-2xl shadow-2xl overflow-hidden border border-slate-200 dark:border-slate-700"
            >
                <div
                    class="aspect-video bg-cover bg-center"
                    data-alt="Growth chart dashboard and marketing analytics mockup"
                    style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDQ81XIHjFJm2uFSYAvRqZ0nJeW5yfqT5ba8vHa0vydp270TJF0_b3UXlqsCKpPwaXBNqjy0-_aYyiMQ_JRgjQy7dVL8UYpgUCgDlbeWaD9EJDF81WKgWiw_3b7BdwgYRXfdWOT3wLuy9LcNGHV1ROhtciEG10TNU0i4tSmWmuCSfFbrSOQaTrpWTxqcJ6mYtxjvrW0KvLZSJx_4LTdm_zfgXpiX_yBM6HVed5wW89cZ1dpc5-RJSLT52v9V_0_9XZzCwKuMQvFVg')"
                >
                </div>
                <div
                    class="p-6 grid grid-cols-3 gap-4 border-t border-slate-100 dark:border-slate-700"
                >
                    <div class="flex flex-col items-center gap-1">
                        <span class="text-primary font-bold text-xl">120h</span>
                        <span
                            class="text-xs text-slate-500 dark:text-slate-400 uppercase font-semibold"
                            >Contenido</span
                        >
                    </div>
                    <div
                        class="flex flex-col items-center gap-1 border-x border-slate-100 dark:border-slate-700"
                    >
                        <span class="text-primary font-bold text-xl">10+</span>
                        <span
                            class="text-xs text-slate-500 dark:text-slate-400 uppercase font-semibold"
                            >Proyectos</span
                        >
                    </div>
                    <div class="flex flex-col items-center gap-1">
                        <span class="text-primary font-bold text-xl">24/7</span>
                        <span
                            class="text-xs text-slate-500 dark:text-slate-400 uppercase font-semibold"
                            >Soporte</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
