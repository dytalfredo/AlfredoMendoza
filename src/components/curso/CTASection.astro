---
// src/components/curso/CtaSection.astro
---

<section class="px-6 lg:px-20 py-24 bg-[#1e1b4b] relative overflow-hidden">
    <div class="absolute inset-0 bg-primary/20 pattern-dots"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10 animate-fade-in-up">
        <h2 class="text-4xl lg:text-6xl font-black text-white mb-8">
            Empieza tu carrera en marketing digital hoy
        </h2>
        <p class="text-white/80 text-xl mb-12">
            No dejes que la IA sea tu competencia. Haz que sea tu mejor
            empleada.
        </p>

        <button
            class="flex min-w-[280px] mx-auto cursor-pointer items-center justify-center rounded-full h-16 px-12 bg-gradient-to-r from-primary to-terracotta text-white text-2xl font-black shadow-[0_0_40px_-10px_rgba(249,115,22,0.8)] hover:shadow-[0_0_60px_-15px_rgba(249,115,22,1)] hover:scale-105 transition-all duration-300 animate-pulse-slow"
        >
            Reservar mi lugar
        </button>
    </div>
</section>
