---
// src/components/curso/CourseHeader.astro
---

<header
    class="flex items-center justify-between border-b border-white/10 bg-[#0b0e14]/80 backdrop-blur-md px-6 lg:px-20 py-4 sticky top-0 z-50"
>
    <div class="flex items-center gap-2 text-primary">
        <span class="material-symbols-outlined text-3xl">auto_awesome</span>
        <h2 class="text-white text-lg font-bold leading-tight tracking-tight">
            Certificación Marketing IA
        </h2>
    </div>
    <div class="hidden md:flex flex-1 justify-end gap-8">
        <nav class="flex items-center gap-8">
            <a
                class="text-slate-400 text-sm font-medium hover:text-primary transition-colors"
                href="#programa">Programa</a
            >
            <a
                class="text-slate-400 text-sm font-medium hover:text-primary transition-colors"
                href="#herramientas">Herramientas</a
            >
            <a
                class="text-slate-400 text-sm font-medium hover:text-primary transition-colors"
                href="#proyectos">Proyectos</a
            >
            <a
                class="text-slate-400 text-sm font-medium hover:text-primary transition-colors"
                href="#faq">Preguntas</a
            >
        </nav>
        <button
            class="flex min-w-[140px] cursor-pointer items-center justify-center rounded-lg h-10 px-5 bg-accent text-white text-sm font-bold shadow-lg shadow-accent/20 hover:bg-accent/90 transition-all shadow-[0_0_15px_-3px_rgba(249,115,22,0.5)]"
        >
            Reservar mi lugar
        </button>
    </div>
</header>
