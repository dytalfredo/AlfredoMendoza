---
// src/components/curso/FinalProjectSection.astro
---

<section
    class="px-6 lg:px-20 py-32 bg-[#0b0e14] relative overflow-hidden"
    id="proyecto"
>
    <!-- Glow effects in the background -->
    <div
        class="absolute top-1/2 left-0 md:left-1/4 w-[30rem] h-[30rem] bg-primary/15 blur-[120px] rounded-full mix-blend-screen pointer-events-none transform -translate-y-1/2"
    >
    </div>
    <div
        class="absolute top-1/2 right-0 md:right-1/4 w-[30rem] h-[30rem] bg-terracotta/15 blur-[120px] rounded-full mix-blend-screen pointer-events-none transform -translate-y-1/2"
    >
    </div>

    <div class="max-w-7xl mx-auto">
        <div
            class="bg-slate-900/80 backdrop-blur-xl border border-slate-800 rounded-[2.5rem] flex flex-col lg:flex-row shadow-[0_0_50px_-12px_rgba(249,115,22,0.15)] animate-fade-in-up relative z-10"
        >
            <!-- Text Content -->
            <div
                class="p-10 lg:p-20 flex flex-col gap-8 lg:w-1/2 justify-center"
            >
                <div class="inline-flex items-center gap-3">
                    <span class="flex h-3 w-3 relative">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-3 w-3 bg-primary"
                        ></span>
                    </span>
                    <span
                        class="text-primary font-black text-sm md:text-base uppercase tracking-[0.2em]"
                    >
                        Hito Final
                    </span>
                </div>

                <h2
                    class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight"
                >
                    Tu Proyecto <br /><span
                        class="text-transparent bg-clip-text bg-linear-to-r from-primary to-terracotta"
                        >Integrador</span
                    >
                </h2>

                <p class="text-slate-400 text-lg md:text-xl leading-relaxed">
                    No es un examen teórico, es tu primer éxito profesional.
                    Construirás un <strong class="text-slate-200"
                        >portafolio estratégico completo</strong
                    > que incluye:
                </p>

                <ul class="space-y-4">
                    <li class="flex items-center gap-4 text-slate-300">
                        <span
                            class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 border border-white/10 text-primary material-symbols-outlined"
                            >edit_square</span
                        >
                        <span>Plan integral de contenidos</span>
                    </li>
                    <li class="flex items-center gap-4 text-slate-300">
                        <span
                            class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 border border-white/10 text-primary material-symbols-outlined"
                            >campaign</span
                        >
                        <span>Campañas publicitarias activas</span>
                    </li>
                    <li class="flex items-center gap-4 text-slate-300">
                        <span
                            class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 border border-white/10 text-primary material-symbols-outlined"
                            >web</span
                        >
                        <span>Landing Page de alta conversión</span>
                    </li>
                </ul>
            </div>

            <!-- Image Showcase -->
            <div
                class="lg:w-1/2 relative bg-slate-950/60 min-h-[400px] lg:min-h-[600px] flex items-center justify-center p-8 lg:p-16 overflow-hidden lg:rounded-r-[2.5rem] rounded-b-[2.5rem] lg:rounded-bl-none group"
            >
                <!-- Inner glow behind image -->
                <div
                    class="absolute inset-0 bg-linear-to-tr from-primary/10 to-transparent"
                >
                </div>
                <div
                    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[length:24px_24px]"
                >
                </div>

                <img
                    src="/portfolio_mockup.png"
                    alt="Mockup de Portafolio Estratégico"
                    class="relative z-10 w-full max-w-[500px] h-auto object-contain transform group-hover:scale-[1.05] group-hover:-translate-y-4 transition-transform duration-700 drop-shadow-[0_20px_50px_rgba(0,0,0,0.6)]"
                />
            </div>
        </div>
    </div>
</section>
