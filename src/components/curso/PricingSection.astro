---
// src/components/curso/PricingSection.astro
---

<section class="px-6 lg:px-20 py-20 bg-[#0b0e14]">
    <div class="max-w-4xl mx-auto">
        <div
            class="bg-slate-900 text-white rounded-3xl p-10 lg:p-16 border border-slate-800 shadow-2xl relative overflow-hidden animate-fade-in-up"
        >
            <div class="absolute top-0 right-0 p-8">
                <span
                    class="bg-accent px-4 py-2 rounded-full text-xs font-black uppercase tracking-widest animate-pulse"
                    >Oferta Lanzamiento</span
                >
            </div>

            <h2 class="text-3xl lg:text-4xl font-bold mb-8">
                Inversión en tu Futuro
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <ul class="space-y-4">
                    <li class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-accent"
                            >verified</span
                        > 120 horas de formación
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-accent"
                            >verified</span
                        > Clases en vivo + Grabaciones
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-accent"
                            >verified</span
                        > 10+ Proyectos prácticos
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-accent"
                            >verified</span
                        > Manual de Prompts exclusivo
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-accent"
                            >verified</span
                        > Certificado profesional
                    </li>
                </ul>

                <div
                    class="flex flex-col justify-center items-start md:items-end gap-6"
                >
                    <div class="flex flex-col">
                        <span class="text-slate-400 line-through text-lg"
                            >$1,200 USD</span
                        >
                        <span class="text-5xl font-black text-white"
                            >$199 <span
                                class="text-lg font-normal text-slate-400"
                                >USD</span
                            ></span
                        >
                    </div>

                    <button
                        class="w-full md:w-auto min-w-[240px] cursor-pointer items-center justify-center rounded-xl h-14 px-8 bg-gradient-to-r from-primary to-terracotta text-white text-xl font-black shadow-[0_0_30px_-5px_rgba(249,115,22,0.6)] hover:shadow-[0_0_40px_-5px_rgba(249,115,22,0.9)] hover:scale-105 transition-all duration-300"
                    >
                        Inscribirme ahora
                    </button>

                    <p class="text-xs text-slate-500 uppercase tracking-widest">
                        Garantía de satisfacción de 15 días
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
